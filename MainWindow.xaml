<Window x:Class="lab4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab4"
        mc:Ignorable="d"
        Title="Collection Processing" Height="520" Width="860"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" LastChildFill="True">
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Collection Processing (Delegates)"/>
            <TextBlock Margin="12,4,0,0" Foreground="#666" DockPanel.Dock="Right"
                       Text="Enter numbers, choose an operation, then process."/>
        </DockPanel>

        <!-- Controls -->
        <Border Grid.Row="2" Padding="12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- Input -->
                <StackPanel Grid.Column="0">
                    <TextBlock FontWeight="SemiBold" Text="Input numbers"/>
                    <TextBlock Foreground="#666" Margin="0,2,0,6"
                               Text="Separate by commas, spaces, or new lines (e.g. 1, 2 3&#10;4.5)"/>
                    <TextBox x:Name="InputTextBox"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Height="180"
                             TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Options -->
                <StackPanel Grid.Column="2">
                    <TextBlock FontWeight="SemiBold" Text="Operation"/>
                    <ComboBox x:Name="OperationBox"
                              Margin="0,6,0,12"
                              SelectionChanged="ComboBox_SelectionChanged">
                        <ComboBoxItem Content="Square"/>
                        <ComboBoxItem Content="Square Root"/>
                        <ComboBoxItem Content="Reciprocal"/>
                    </ComboBox>

                    <Button Content="Process Collection"
                            Height="32"
                            Click="ProcessCollectionButton_Click"/>

                    <Button Content="Load Sample"
                            Margin="0,8,0,0"
                            Height="28"
                            Click="LoadSampleButton_Click"/>

                    <Button Content="Clear"
                            Margin="0,8,0,0"
                            Height="28"
                            Click="ClearButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Output -->
        <Border Grid.Row="4" Padding="12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock FontWeight="SemiBold" Text="Output"/>
                <TextBox x:Name="OutputTextBox"
                         Grid.Row="2"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"/>

                <TextBlock x:Name="ResultText"
                           Grid.Row="3"
                           Margin="0,10,0,0"
                           Foreground="#333"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="5" Margin="0,10,0,0" Foreground="#666"
                   Text="Tip: Square Root rejects negative inputs; Reciprocal rejects zero."/>
    </Grid>
</Window>