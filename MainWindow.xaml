<Window x:Class="lab4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab4"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <ComboBox x:Name="OperationBox" HorizontalAlignment="Left" VerticalAlignment="Top" Width="157" Margin="44,33,0,0" SelectionChanged="ComboBox_SelectionChanged" >
            <ComboBoxItem Content="Square"/>
            <ComboBoxItem Content="Square Root"/>
            <ComboBoxItem Content="Reciprocal"/>
        </ComboBox>

        <TextBlock x:Name="ResultText" Margin="241,33,32.6,365" RenderTransformOrigin="0.5,0.5"/>
        <TextBox x:Name="Txtbox1" HorizontalAlignment="Left" Height="23" Margin="44,77,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="157"/>
        <Button Content="Calculate" HorizontalAlignment="Left" Margin="241,77,0,0" VerticalAlignment="Top" Width="151" Height="23" Click="Button_Click"/>
    </Grid>
</Window>
