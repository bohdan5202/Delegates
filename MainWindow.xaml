<Window x:Class="lab4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab4"
        mc:Ignorable="d"
        Title="Collection Processing" Height="712" Width="1106"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" LastChildFill="True">
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Collection Processing (Delegates)"/>
            <TextBlock Margin="12,4,0,0" Foreground="#666" DockPanel.Dock="Right"
                       Text="Enter numbers, choose an operation, then process."/>
        </DockPanel>

        <!-- Controls -->
        <Border Grid.Row="2" Padding="12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- Input -->
                <StackPanel Grid.Column="0">
                    <TextBlock FontWeight="SemiBold" Text="Input numbers"/>
                    <TextBlock Foreground="#666" Margin="0,2,0,6"
                               Text="Separate by commas, spaces, or new lines (e.g. 1, 2 3&#10;4.5)"/>
                    <TextBox x:Name="InputTextBox"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Height="106"
                             TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Options -->
                <StackPanel Grid.Column="2">
                    <TextBlock FontWeight="SemiBold" Text="Operation"/>
                    <ComboBox x:Name="OperationBox"
                              Margin="0,6,0,12"
                              SelectionChanged="ComboBox_SelectionChanged">
                        <ComboBoxItem Content="Square"/>
                        <ComboBoxItem Content="Square Root"/>
                        <ComboBoxItem Content="Reciprocal"/>
                    </ComboBox>

                    <Button Content="Process Collection"
                            Height="32"
                            Click="ProcessCollectionButton_Click"/>

                    <Button Content="Load Sample"
                            Margin="0,8,0,0"
                            Height="28"
                            Click="LoadSampleButton_Click"/>

                    <Button Content="Clear"
                            Margin="0,8,0,0"
                            Height="28"
                            Click="ClearButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Output -->
        <Border Grid.Row="4" Padding="12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock FontWeight="SemiBold" Text="Output"/>
                <TextBox x:Name="OutputTextBox"
                         Grid.Row="2"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"/>

                <TextBlock x:Name="ResultText"
                           Grid.Row="3"
                           Margin="0,10,0,0"
                           Foreground="#333"
                           Text="(status)"/>
            </Grid>
        </Border>

        <!-- Multicast Delegate UI Styling Test -->
        <Border Grid.Row="6" Padding="12" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.6*"/>
                </Grid.ColumnDefinitions>

                <!-- Choose which methods are in the multicast list -->
                <StackPanel Grid.Column="0">
                    <TextBlock FontWeight="SemiBold" Text="UI Styling Test (Multicast Delegate)"/>
                    <TextBlock Foreground="#666" Margin="0,2,0,10"
                               Text="Select methods to include, then build + invoke."/>
                    <CheckBox x:Name="BgMethodCheckBox" Content="Change background color" IsChecked="True"/>
                    <CheckBox x:Name="FgMethodCheckBox" Content="Change label (ResultText) font color" IsChecked="True" Margin="0,6,0,0"/>
                    <CheckBox x:Name="SizeMethodCheckBox" Content="Change label (ResultText) font size" IsChecked="True" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Background picker -->
                <StackPanel Grid.Column="2">
                    <TextBlock FontWeight="SemiBold" Text="Background color"/>
                    <ComboBox x:Name="BackgroundColorBox" Margin="0,6,0,0" SelectedIndex="0">
                        <ComboBoxItem Content="Dark"/>
                        <ComboBoxItem Content="Light"/>
                        <ComboBoxItem Content="Blue"/>
                        <ComboBoxItem Content="Green"/>
                    </ComboBox>
                    <!-- Sorting (delegate-based comparer) -->
                    <Separator Margin="0,14,0,10"/>
                    <TextBlock FontWeight="SemiBold" Text="Sorting"/>

                    <StackPanel Margin="0,6,0,0">
                        <RadioButton x:Name="AscRadio"
                         Content="Ascending"
                         GroupName="SortOrder"
                         IsChecked="True"/>
                        <RadioButton x:Name="DescRadio"
                         Content="Descending"
                         GroupName="SortOrder"
                         Margin="0,6,0,0"/>
                    </StackPanel>

                    <Button Content="Sort Input"
                        Margin="0,10,0,0"
                        Height="30"
                        Click="SortInputButton_Click"/>
                </StackPanel>

                <!-- Foreground picker + size slider -->
                <StackPanel Grid.Column="4">
                    <TextBlock FontWeight="SemiBold" Text="Label style (ResultText)"/>
                    <TextBlock Margin="0,6,0,0" Text="Font color"/>
                    <ComboBox x:Name="FontColorBox" Margin="0,6,0,0" SelectedIndex="0">
                        <ComboBoxItem Content="Orange"/>
                        <ComboBoxItem Content="White"/>
                        <ComboBoxItem Content="Black"/>
                        <ComboBoxItem Content="Red"/>
                    </ComboBox>

                    <TextBlock Margin="0,10,0,0" Text="Font size"/>
                    <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="40" Value="22"
                            TickFrequency="2" IsSnapToTickEnabled="True"
                            Margin="0,6,0,0"/>
                    <TextBlock x:Name="FontSizeValueText" Foreground="#666" Margin="0,4,0,0"
                               Text="Selected size: 22"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Build Multicast" Width="140" Height="30" Click="BuildMulticastButton_Click"/>
                        <Button Content="Invoke Multicast" Width="140" Height="30" Margin="10,0,0,0" Click="InvokeMulticastButton_Click"/>
                        <Button Content="Reset UI" Width="100" Height="30" Margin="10,0,0,0" Click="ResetUiButton_Click"/>
                    </StackPanel>
                </StackPanel>
                
            </Grid>
            
        </Border>
    </Grid>
</Window>